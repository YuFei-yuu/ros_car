  </link>

  <joint
    name="joint5"
    type="revolute">
    <origin
      xyz="-0.0010116 -0.018014 0.05577"
      rpy="0 0 0" />
    <parent
      link="$(arg prefix)link4" />
    <child
      link="$(arg prefix)link5" />
    <axis
      xyz="0 0 -1" />
    <limit
      lower="-2.09"
      upper="2.09"
      effort="1000"
      velocity="10" />
  </joint>

  <link
    name="$(arg prefix)gripper_link">
    <inertial>
      <origin
        xyz="0.0231313386895878 -0.00393552713010837 -0.0156882339564593"
        rpy="0 0 0" />
      <mass
        value="0.0262978257351592" />
      <inertia
        ixx="3.95387110327665E-06"
        ixy="-1.19832857387574E-12"
        ixz="2.46427244487644E-12"
        iyy="1.3233558568295E-06"
        iyz="1.37213951357202E-08"
        izz="4.22515071659295E-06" />
    </inertial>
    <visual>
      <origin
