      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rosorin_description)/meshes/pro/arm/link3.stl" />
      </geometry>
    </collision>
  </link>

  <joint
    name="joint3"
    type="revolute">
    <origin
      xyz="0.00025563 0.00074282 0.08513"
      rpy="0 0 0" />
    <parent
      link="$(arg prefix)link2" />
    <child
      link="$(arg prefix)link3" />
    <axis
      xyz="0 1 0" />
    <limit
      lower="-2.09"
      upper="2.09"
      effort="1000"
      velocity="10" />
  </joint>

  <link
    name="$(arg prefix)link4">
    <inertial>
      <origin
        xyz="0.00401889070001946 -0.0185055710062145 0.0267467820937604"
        rpy="0 0 0" />
      <mass
        value="0.0125542777381369" />
      <inertia
        ixx="3.42302406002793E-06"
        ixy="-8.26448821832188E-09"
        ixz="-1.3188503984044E-07"
        iyy="2.90651238927709E-06"
        iyz="8.54505947394019E-09"
        izz="3.34228552880687E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rosorin_description)/meshes/pro/arm/link4.stl" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rosorin_description)/meshes/pro/arm/link4.stl" />
      </geometry>
    </collision>
  </link>

  <joint
    name="joint4"
    type="revolute">
    <origin
      xyz="-0.00056892 0.00074297 0.085147"
      rpy="0 0 0" />
    <parent
      link="$(arg prefix)link3" />
    <child
      link="$(arg prefix)link4" />
    <axis
      xyz="0 1 0" />
    <limit
      lower="-2.09"
      upper="2.09"
      effort="1000"
      velocity="10" />
  </joint>

  <link
    name="$(arg prefix)link5">
    <inertial>
      <origin
        xyz="4.95037712668067E-06 9.72914927224386E-09 -0.0020019811095377"
        rpy="0 0 0" />
      <mass
        value="0.00094700314670666" />
      <inertia
        ixx="2.17248160164777E-08"
        ixy="3.02198013430078E-14"
        ixz="-4.76292817428858E-11"
        iyy="2.17243959579653E-08"
        iyz="7.04450794385081E-14"
        izz="4.04666808778697E-08" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rosorin_description)/meshes/pro/arm/link5.stl" />
      </geometry>
      <material
