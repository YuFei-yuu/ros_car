<?xml version="1.0" encoding="utf-8"?>
<robot name="arm" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:arg name="prefix" default="" />
  <xacro:property name="M_PI"   value="3.1415926535897931"/>

  <link
    name="$(arg prefix)link1">
    <inertial>
      <origin
        xyz="6.49037759326426E-05 0.00239407542452911 0.0110195047829908"
        rpy="0 0 0" />
      <mass
        value="0.010597277181335" />
      <inertia
        ixx="1.46240263881777E-06"
        ixy="-4.78262881626278E-09"
        ixz="7.11910436984689E-09"
        iyy="1.81010848614845E-06"
        iyz="-2.88588688247835E-08"
        izz="1.87119457153925E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rosorin_description)/meshes/pro/arm/link1.stl" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rosorin_description)/meshes/pro/arm/link1.stl" />
      </geometry>
    </collision>
  </link>

  <gazebo reference="$(arg prefix)base_link">
    <material>Gazebo/Grey</material>
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <self_collide>false</self_collide>
  </gazebo>

  <joint
    name="joint1"
    type="revolute">
    <origin
      xyz="0.04662 7.5437E-05 0.16044"
      rpy="0.0087266 0 0" />
    <parent
      link="$(arg prefix)base_link" />
    <child
      link="$(arg prefix)link1" />
    <axis
      xyz="-5.4513E-05 -0.0087266 -0.99996" />
    <limit
      lower="-2.09"
      upper="2.09"
      effort="1000"
      velocity="10" />
  </joint>

  <link
    name="$(arg prefix)link2">
    <inertial>
      <origin
        xyz="0.000202046656795941 -0.0165522680567203 0.0481618179233159"
        rpy="0 0 0" />
      <mass
        value="0.0136322197327749" />
      <inertia
        ixx="3.65656868148961E-06"
        ixy="-4.89058741962216E-09"
        ixz="3.19797719203556E-09"
        iyy="3.1366082581851E-06"
        iyz="-3.55846346498633E-08"
        izz="2.4183678227792E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rosorin_description)/meshes/pro/arm/link2.stl" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rosorin_description)/meshes/pro/arm/link2.stl" />
      </geometry>
    </collision>
  </link>

  <joint
    name="joint2"
    type="revolute">
    <origin
      xyz="1.2011E-05 0.018766 0.030345"
      rpy="0 0 0" />
    <parent
      link="$(arg prefix)link1" />
    <child
      link="$(arg prefix)link2" />
    <axis
      xyz="0 0.99996 -0.0087265" />
    <limit
      lower="-2.09"
      upper="2.09"
      effort="1000"
      velocity="10" />
  </joint>

  <link
    name="$(arg prefix)link3">
    <inertial>
      <origin
        xyz="-0.000248379360253626 -0.016552274463385 0.0481616278776934"
        rpy="0 0 0" />
      <mass
        value="0.0136322449843806" />
      <inertia
        ixx="3.65640771045542E-06"
        ixy="-4.52089983676596E-09"
        ixz="1.4805893818475E-08"
        iyy="3.13662596679787E-06"
        iyz="-3.5627525860988E-08"
        izz="2.41855475274639E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
