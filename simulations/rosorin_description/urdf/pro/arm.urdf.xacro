    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find rosorin_description)/meshes/pro/arm/gripper_link.stl" />
      </geometry>
    </collision>
  </link>

  <joint
    name="gripper_joint"
    type="fixed">
    <origin
      xyz="0 0 0.0030019"
      rpy="-3.1416 -1.5681 3.1416" />
    <parent
      link="$(arg prefix)link5" />
    <child
      link="$(arg prefix)gripper_link" />
    <axis
      xyz="0 0 0" />
  </joint>

  <link name="$(arg prefix)end_effector_link" />

  <joint name="end_effector_joint" type="fixed">
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <parent link="$(arg prefix)link5"/>
    <child link="$(arg prefix)end_effector_link"/>
  </joint>

</robot>